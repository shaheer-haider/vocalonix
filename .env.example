# Vocalonix app
APP_ORIGIN=http://localhost:3000
VITE_API_BASE_URL=http://localhost:3001
VOCALONIX_API_PUBLIC_URL=http://localhost:3001
API_PUBLIC_URL=http://localhost:3001
NODE_ENV=development

# Vocalonix account database and sessions
VOCALONIX_POSTGRES_USER=vocalonix
VOCALONIX_POSTGRES_PASSWORD=
VOCALONIX_POSTGRES_DB=vocalonix
VOCALONIX_POSTGRES_PORT=5433
DATABASE_URL=
AUTH_SECRET=
REQUIRE_EMAIL_VERIFICATION=false
RESEND_API_KEY=
EMAIL_FROM="Vocalonix <hello@vocalonix.ai>"

# Dograh endpoints used by the Vocalonix backend and browser widget
DOGRAH_INTERNAL_URL=http://api:8000
DOGRAH_PUBLIC_API_URL=http://localhost:8000
DOGRAH_WIDGET_URL=http://localhost:3000
DOGRAH_STORAGE_INTERNAL_URL=http://minio:9000
DOGRAH_API_KEY=

# Local Dograh service account. Change these outside local development.
DOGRAH_SERVICE_EMAIL=vocalonix@vocalonix.ai
DOGRAH_SERVICE_PASSWORD=
DOGRAH_SERVICE_NAME=Vocalonix
DOGRAH_WORKFLOW_NAME="Vocalonix Agent"
DOGRAH_WIDGET_ALLOWED_DOMAINS=localhost,127.0.0.1

# Pinned Dograh release
DOGRAH_VERSION=1.41.0
ENVIRONMENT=local
ENABLE_SIGNUP=true
ENABLE_TELEMETRY=false
BACKEND_API_ENDPOINT=http://localhost:8000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
TURN_HOST=localhost

# Generated by scripts/setup.sh
OSS_JWT_SECRET=
POSTGRES_PASSWORD=
REDIS_PASSWORD=
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
