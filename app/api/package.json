    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@elysiajs/cors": "1.1.1",
    "better-auth": "1.6.11",
    "drizzle-orm": "0.45.2",
    "elysia": "1.1.25",
    "postgres": "3.4.9",
    "zod": "4.4.2"
  },
  "devDependencies": {
    "@types/bun": "1.1.14",
    "drizzle-kit": "0.31.10",
    "typescript": "5.7.3"
  }
}
