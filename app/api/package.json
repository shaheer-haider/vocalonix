{
  "name": "@vocalonix/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "worker": "bun src/worker.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
